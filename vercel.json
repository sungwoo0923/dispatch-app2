{
  "functions": {
    "api/fuel.js": {
      "maxDuration": 10,
      "regions": ["icn1"]
    },
    "api/send-email.js": {
      "maxDuration": 30,
      "regions": ["icn1"]
    },
    "api/send24.js": {
      "maxDuration": 30,
      "regions": ["icn1"]
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}