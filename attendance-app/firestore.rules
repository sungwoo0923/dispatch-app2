rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Platform owner: reviews new-company applications regardless of which
    // company (if any) their own admin account belongs to. Identity is the
    // Auth email itself (mirrors src/constants/superAdmin.js) rather than a
    // Firestore-stored flag, so no data migration is needed for the account
    // that already existed before this role was introduced.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'sungwoo0923@nate.com';
    }

    // Denormalized {companyId} doc per admin account, kept in its own
    // collection (never `users`) so admin-permission checks never have to
    // read the same collection/document a rule is currently gating for a
    // `list` query — that self-referential pattern is unreliable (crashes
    // the client SDK on some Firestore/emulator versions) and best avoided
    // even in production.
    function isAdminOf(companyId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.companyId == companyId
        )
      );
    }

    // 사내 메신저 규칙에서 "내 회사"를 판별할 때 쓴다 — 관리자는 admins/{uid},
    // 근로자는 users/{uid}에 companyId가 있다.
    function myCompanyId() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        ? get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.companyId
        : (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
            : null
        );
    }

    match /admins/{uid} {
      allow get: if isSelf(uid);
      allow list: if false;
      allow create: if isSelf(uid);
      allow update, delete: if false;
    }

    // 사이드바 메뉴별 "안읽음 배지" 확인 시각 — 관리자 계정별로 자기 것만
    // 읽고 쓸 수 있다 (다른 관리자가 봤다고 내 배지가 사라지면 안 되므로).
    match /adminReadState/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /companies/{companyId} {
      allow get: if true; // invite-code lookup during employee signup, before auth exists
      allow list: if isSuperAdmin(); // 플랫폼 관리 > 회사 개설 신청 목록
      allow create: if isSignedIn();
      allow update: if isAdminOf(companyId) || isSuperAdmin();
      allow delete: if isAdminOf(companyId);
    }

    match /users/{uid} {
      allow get: if isSelf(uid) || isAdminOf(resource.data.companyId);
      allow list: if isAdminOf(resource.data.companyId);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSelf(uid) || isAdminOf(resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // Work site info (name/coords/radius) has no PII, so any signed-in
    // company member may read it; only admins may write.
    match /workSites/{siteId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 근무정보 > 배정변경 요청: employee requests a different 근무지/소속업체;
    // admin approves (writes the change to users) or rejects.
    match /assignmentChangeRequests/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdminOf(resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 내정보 > 기본정보 최초 저장 후 잠긴 값을 근로자가 스스로 못 고치고
    // 관리자에게 수정을 요청하는 문서 — 승인/반려는 관리자만 할 수 있다.
    match /infoChangeRequests/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdminOf(resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 소속업체 (subcontracting vendor names) — same low-sensitivity pattern as workSites.
    match /vendors/{vendorId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /attendance/{docId} {
      // docId is `${date}_${uid}`; a direct get() for "have I checked in
      // today?" happens before the document necessarily exists, and
      // `resource` is null for a not-yet-created doc — dereferencing
      // resource.data in that case throws rather than cleanly denying, so
      // the self-check-in `get` is authorized from the docId alone instead.
      allow get: if isSignedIn() && docId.split('_')[1] == request.auth.uid;
      allow list: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create, update: if isSignedIn() &&
        (request.resource.data.uid == request.auth.uid || isAdminOf(request.resource.data.companyId));
    }

    // Audit trail of admin corrections to a worker's recorded check-in/out
    // time, shown under 출근현황 > 수정현황.
    match /attendanceEdits/{editId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isAdminOf(request.resource.data.companyId);
    }

    // 근로자가 본인의 출근/퇴근 기록 시각 변경을 요청하고, 관리자가
    // 승인/반려한다 — 승인 시 실제 attendance 문서 반영은 관리자 계정으로
    // 별도로 이루어진다(이 문서 자체는 요청/결정 이력만 담는다).
    match /attendanceChangeRequests/{reqId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdminOf(resource.data.companyId);
      allow delete: if false;
    }

    // 모바일 계약관리/급여관리/휴가관리의 3개월 조회 제한을 넘어서고 싶을 때
    // 근로자가 관리자에게 보내는 확장 요청. 승인되면 users/{uid}의
    // extendedHistoryAccess를 관리자가 직접 true/false로 바꾼다.
    match /historyAccessRequests/{reqId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdminOf(resource.data.companyId);
      allow delete: if false;
    }

    match /leaves/{leaveId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() &&
        (request.resource.data.uid == request.auth.uid || isAdminOf(request.resource.data.companyId));
      allow update: if isSignedIn() &&
        (isAdminOf(resource.data.companyId) || (resource.data.uid == request.auth.uid && resource.data.status == 'pending'));
      // 승인/반려 전(pending)에는 신청 본인이 취소할 수 있고, 이후에는 관리자만 삭제 가능.
      allow delete: if isSignedIn() &&
        (isAdminOf(resource.data.companyId) || (resource.data.uid == request.auth.uid && resource.data.status == 'pending'));
    }

    // 월별 스케줄표(출근현황) 각 근로자 행의 비고 메모 — docId가
    // `${month}_${uid}`라 관리자가 그대로 setDoc(merge)으로 덮어쓴다.
    match /scheduleRemarks/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 근로자 개인 알림(조퇴 승인/거절 등) — 관리자가 발행하고 본인만 읽고
    // 읽음 처리할 수 있다.
    match /notifications/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      // 관리자가 직원에게 보내는 경우뿐 아니라, 지각/결근 자동 알림처럼 직원
      // 클라이언트가 "관리자에게" 보내야 하는 경우도 있어 같은 회사 내
      // 발신은 역할과 무관하게 허용한다.
      allow create: if isAdminOf(request.resource.data.companyId) ||
        (isSignedIn() && myCompanyId() == request.resource.data.companyId);
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
    }

    // 안전교육자료(지침/영상) — 회사 소속 로그인 사용자 누구나 조회 가능(직원이
    // 시청해야 하므로), 등록/삭제는 관리자만.
    match /safetyMaterials/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 안전교육 이수 기록 — 본인 것은 본인이 쓰고(이수 서명), 조회는 본인과
    // 관리자만 가능하다.
    match /safetyCompletions/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 안전 > 감사자료 > 점검 이력: 근로감독관/내부감사 방문 기록. 근로자에게
    // 노출될 이유가 없는 순수 관리자용 행정기록이라, safetyMaterials/
    // safetyCompletions와 달리 읽기도 관리자 전용으로 좁힌다.
    match /complianceAuditLogs/{id} {
      allow read: if isAdminOf(resource.data.companyId);
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 휴가 > 휴가템플릿/휴가유형설정/센터별휴가설정: company-wide config docs.
    match /leaveTemplates/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /leaveTypes/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /siteLeaveSettings/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 근로자등록 화면의 복사/템플릿일괄적용 액션 audit trail (변경이력).
    match /employeeChangeLogs/{id} {
      allow read: if isSignedIn();
      allow create: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /shiftTemplates/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /allowanceTemplates/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /insuranceRateTemplates/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // Sub-rows of a 보험요율 master template (템플릿 > 보험요율 상세).
    match /insuranceRateElements/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 템플릿 > 센터별리포트: electronic document format registry (계약서/사직서/
    // 안전교육일지/재직증명서/퇴직증명서/급여명세서).
    match /centerReports/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // Which insurance rate template applies to a site as of a given
    // effectiveDate; payroll settlement reads the most recent entry <= the
    // settlement period to compute deductions.
    match /siteInsuranceRates/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /departments/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /positions/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 조직: 사업자 (business entity), parent of 센터/소속업체.
    match /businessEntities/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 조직: 센터<->소속업체 link table.
    match /siteVendors/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 조직: 센터-scoped 근무구분/근무형태/부서/직급/지정외휴일 (each row belongs to one workSite).
    match /siteShiftCategories/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /siteShiftTypes/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /siteDepartments/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /sitePositions/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /siteHolidays/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 조직: 디바이스 (beacon/tablet registry, record-keeping only) + site assignment link.
    match /devices/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /siteDevices/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 권한: 그룹등록/그룹소속/그룹별메뉴.
    match /permissionGroups/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /permissionGroupMembers/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }
    match /permissionGroupMenus/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // Single-use code an existing admin issues so a co-worker can join as a
    // second admin of the same company (mirrors pendingEmployees' pattern).
    match /adminInvites/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdminOf(request.resource.data.companyId);
      allow delete: if isSignedIn();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isAdminOf(request.resource.data.companyId);
      // 조회수 기록: 같은 회사 구성원이라면 viewedBy 필드만 바꾸는 조건으로
      // 본인 uid를 추가할 수 있다 (그 외 필드 변경은 여전히 관리자만 가능).
      allow update: if isAdminOf(resource.data.companyId) ||
        (isSignedIn() && myCompanyId() == resource.data.companyId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["viewedBy"]));
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 사내 자유게시판: 공지사항(posts, 관리자 전용 작성)과 달리 직원/관리자
    // 누구나 글을 쓸 수 있는 게시판. 같은 회사 구성원만 읽고 쓸 수 있고,
    // 본인 글은 본인이, 그 외에는 관리자만 삭제할 수 있다.
    match /freePosts/{postId} {
      allow read: if isSignedIn() && myCompanyId() == resource.data.companyId;
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.companyId == myCompanyId();
      allow delete: if isSignedIn() &&
        (resource.data.authorUid == request.auth.uid || isAdminOf(resource.data.companyId));
    }

    // Admin's pre-registered e-signature image, used to auto-stamp safety
    // education attendance records alongside the worker's own signature.
    // Kept in its own collection (not `users`) so any signed-in company
    // member can read it (needed client-side to render the stamp) without
    // widening read access to admin profile data.
    match /adminSignatures/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);
    }

    // Per-site designated safety roles (총괄책임자/안전관리자/담당반장/관리감독자),
    // each linked to an admin uid whose adminSignatures doc supplies the stamp.
    match /safetyManagers/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    match /siteSafetyReports/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // Metadata only; actual file bytes live in Storage under
    // companies/{companyId}/employees/{uid}/, gated by storage.rules.
    match /documents/{docId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() &&
        (request.resource.data.uid == request.auth.uid || isAdminOf(request.resource.data.companyId));
      allow delete: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      // 계약서는 보통 관리자가 발송하지만, 근로자등록에서 "자동발송"을
      // 켜둔 경우 근로자 본인이 모바일 첫 로그인 시 자기 자신의 계약서를
      // 1건 생성한다 — 그 경로만 허용하기 위해 본인 uid이면서 자신이
      // 속한 회사(users/{uid}.companyId)와 일치할 때만 셀프 생성을 허용한다.
      allow create: if isAdminOf(request.resource.data.companyId) ||
        (isSelf(request.resource.data.uid) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == request.resource.data.companyId);
      // 근로자는 자신의 계약서에 아직 서명이 없을 때 딱 한 번만 서명할 수
      // 있다 — 이미 서명한 뒤에는 재서명(수정)이 불가능해야 하므로, 서명
      // 필드가 비어있는 경우에만 본인 문서 갱신을 허용한다. 회사 측
      // 서명/도장 적용 등은 관리자가 언제든 갱신할 수 있다.
      allow update: if isSignedIn() &&
        (isAdminOf(resource.data.companyId) ||
          (resource.data.uid == request.auth.uid &&
            (!('employeeSignatureDataUrl' in resource.data) || resource.data.employeeSignatureDataUrl == null)));
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 사직서: 관리자가 근로자에게 템플릿을 배정하면 생성되고, 근로자 서명 →
    // 담당 결재 → 대표 결재 순으로 진행된다. 근로자는 자신의 서명 단계만
    // (본인 문서 갱신 형태로) 채울 수 있고, 결재 단계는 관리자만 채운다.
    match /resignationRequests/{id} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isAdminOf(request.resource.data.companyId);
      allow update: if isSignedIn() &&
        (isAdminOf(resource.data.companyId) || resource.data.uid == request.auth.uid);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // 근로자 문의/건의 — 작성자 본인과 문의를 받은 관리자만 조회 가능. 다른
    // 근로자에게는 절대 노출되지 않는 1:1 문의함이다.
    match /inquiries/{id} {
      allow read: if isSignedIn() &&
        (resource.data.fromUid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAdminOf(resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId) || resource.data.fromUid == request.auth.uid;
    }

    match /payrolls/{payrollId} {
      // payrollId is `${month}_${uid}`; same not-yet-created-doc reasoning as attendance above.
      allow get: if isSignedIn() && payrollId.split('_')[1] == request.auth.uid;
      allow list: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isAdminOf(resource.data.companyId));
      allow create, update: if isAdminOf(request.resource.data.companyId);
      allow delete: if isAdminOf(resource.data.companyId);
    }

    // Admin pre-registers a worker's profile here under a one-time personal
    // join code (doc id); the worker looks it up (get, pre-auth) during
    // signup to prefill their info, then the doc is deleted once claimed.
    match /pendingEmployees/{code} {
      allow get: if true;
      allow list: if isAdminOf(resource.data.companyId);
      allow create: if isAdminOf(request.resource.data.companyId);
      allow update: if isAdminOf(resource.data.companyId);
      // Deletable by any signed-in user because the worker who just claimed
      // the code (via a fresh, not-yet-admin account) must be able to clear
      // it too; the doc holds no sensitive data beyond name/phone/companyId.
      allow delete: if isSignedIn();
    }

    // ── 사내 메신저 (KP-Flow 메신저를 그대로 이식) ──
    // 프로필: 이름/사진/상태메시지 등 민감하지 않은 정보라 같은 회사
    // 구성원끼리는 서로 조회 가능해야 친구 목록을 만들 수 있다. 본인 것만
    // 쓸 수 있다.
    match /chat_profiles/{uid} {
      allow read: if isSignedIn() && (isSelf(uid) || isSuperAdmin() || resource.data.company == myCompanyId());
      allow create: if (isSelf(uid) && (isSuperAdmin() || request.resource.data.company == myCompanyId()))
        || isAdminOf(request.resource.data.company);
      allow update: if isSelf(uid) || isAdminOf(resource.data.company);
      allow delete: if false;
    }

    // 채팅방: 멤버만 읽고 쓸 수 있다. 생성 시 나 자신이 멤버 목록에
    // 포함되어야 하고, 수정(읽음처리/안읽음카운트/나가기)도 기존 멤버만.
    // company == myCompanyId() 비교는 플랫폼 슈퍼관리자가 "다른 회사"로
    // 전환해 들어간 상태에서는 항상 실패한다(myCompanyId()는 본인 소속
    // 회사만 알고, 클라이언트의 회사 전환 상태를 모르기 때문) — 그래서
    // 슈퍼관리자로 테스트할 때 채팅방 생성(=메시지 전송)이 계속
    // 실패했었다. isSuperAdmin()이면 이 비교를 건너뛴다.
    match /chat_rooms/{roomId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members
        && (isSuperAdmin() || request.resource.data.company == myCompanyId());
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow delete: if false;
    }

    // 메시지: 그 방의 멤버만 읽고 쓸 수 있다. 작성은 본인 명의로만, 수정은
    // (읽음표시/이모티콘 반응/수정·삭제 모두) 같은 방 멤버 누구나 가능하게
    // 열어둔다 — KP-Flow 원본과 동일한 구성.
    match /chat_messages/{msgId} {
      allow read: if isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(resource.data.roomId)).data.members;
      allow create: if isSignedIn() && request.resource.data.senderUid == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(request.resource.data.roomId)).data.members;
      allow update: if isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(resource.data.roomId)).data.members;
      allow delete: if false;
    }
  }
}
