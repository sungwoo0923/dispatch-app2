rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Employee documents live at companies/{companyId}/employees/{uid}/{fileName}.
    // Cross-service read of the `admins` Firestore collection mirrors the
    // isAdminOf() pattern used in firestore.rules — checked with exists()
    // first since get() on a missing doc throws rather than denying cleanly.
    match /companies/{companyId}/employees/{uid}/{fileName} {
      function isSelfOrCompanyAdmin() {
        return request.auth != null && (
          request.auth.uid == uid ||
          (
            firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
            firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.companyId == companyId
          )
        );
      }

      allow read: if isSelfOrCompanyAdmin();
      allow write: if isSelfOrCompanyAdmin() && request.resource.size < 10 * 1024 * 1024;
    }

    // 근로자등록(첨부서류 탭)에서 아직 uid가 없는 근로자에게 첨부한 서류.
    // 가입코드(pendingCode) 기준 경로이므로 회사 관리자만 접근 가능.
    match /companies/{companyId}/pending/{pendingCode}/{fileName} {
      function isCompanyAdmin() {
        return request.auth != null &&
          firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.companyId == companyId;
      }

      allow read: if isCompanyAdmin();
      allow write: if isCompanyAdmin() && request.resource.size < 10 * 1024 * 1024;
    }

    // 사업자(businessEntities)의 인감/서명 도장 이미지 — 센터별리포트 > 계약서
    // 상세에서 업로드하며, 전자문서의 갑(회사) 서명란에 표시된다.
    match /companies/{companyId}/entities/{entityId}/{fileName} {
      function isCompanyAdmin() {
        return request.auth != null &&
          firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.companyId == companyId;
      }

      allow read: if request.auth != null;
      allow write: if isCompanyAdmin() && request.resource.size < 10 * 1024 * 1024;
    }

    // 안전교육자료(지침 영상 등) — 영상 파일은 용량이 크므로 다른 업로드보다
    // 훨씬 넉넉한 용량 제한(200MB)을 둔다. 읽기는 같은 회사 로그인 사용자
    // 누구나(직원이 시청해야 하므로), 쓰기(업로드)는 회사 관리자만 가능하다.
    match /companies/{companyId}/safety-materials/{materialId}/{fileName} {
      function isCompanyAdmin() {
        return request.auth != null &&
          firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.companyId == companyId;
      }

      allow read: if request.auth != null;
      allow write: if isCompanyAdmin() && request.resource.size < 200 * 1024 * 1024;
    }
  }
}
